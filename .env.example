# --- Identidad del servidor ---
SERVER_NAME=Mi Server PZ B42
SERVER_PUBLIC_NAME=Mi Server PZ B42
SERVER_PUBLIC_DESCRIPTION=Servidor privado vanilla, sin mods, Build 42
# Public=true aparece en la lista publica de Internet. Public=false requiere IP:port directo.
SERVER_PUBLIC=false

# --- Puertos del juego (UDP) ---
# 16261 = puerto principal del juego.
# 16262 = puerto UDP secundario (UDPPort en servertest.ini).
SERVER_PORT=16261
SERVER_PORT2=16262

# --- Reglas de juego ---
SERVER_PASSWORD=
# MEMORY es la RAM dedicada al servidor (Jvm Xms/Xmx). 2G va bien para 8 jugadores.
SERVER_MEMORY=2048m
RCON_PASSWORD=

# --- Admin del juego ---
# En juego: nombre de usuario 'admin', password = ADMIN_PASSWORD.
# La primera vez es obligatorio, luego puedes borrarla del .env para que no quede en logs.
ADMIN_PASSWORD=cambia_este_password_admin

# --- Panel Web (credenciales para entrar a http://localhost:8080) ---
PANEL_USERNAME=admin
PANEL_PASSWORD=cambia_este_password_panel

# --- No suele ser necesario tocar esto ---
# Nombre del archivo INI del servidor (segun SERVERNAME del server). Por defecto el server se llama "servertest".
SERVER_INI_NAME=servertest.ini
SANDBOX_NAME=servertest_SandboxVars.lua

# --- IPs para mostrar en el panel web ---
# LOCAL_IP: IP de tu PC en la red local (la que ven tus amigos en LAN). Dejala vacia para auto-detectar.
#   En Windows puedes verla con `ipconfig` (Direccion IPv4). Ejemplo: 192.168.1.50
LOCAL_IP=
# PUBLIC_IP: tu IP publica (la que ven desde Internet). Dejala vacia para auto-detectar via api.ipify.org.
#   Sobreescribela si tienes dominio dinamico (DuckDNS, No-IP, etc.) o si tu ISP usa CGNAT y prefieres no mostrarla.
PUBLIC_IP=
